<Window x:Class="PdfMergeTool.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="설정"
        Width="560"
        Height="520"
        MinWidth="520"
        MinHeight="460"
        Background="#F5F7FA"
        FontFamily="Segoe UI Variable, Segoe UI"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <SolidColorBrush x:Key="InkBrush" Color="#1F2937" />
        <SolidColorBrush x:Key="MutedBrush" Color="#6B7280" />
        <SolidColorBrush x:Key="LineBrush" Color="#D9E1EC" />
        <Style TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,14">
            <TextBlock Text="설정"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="{StaticResource InkBrush}" />
            <TextBlock Text="Windows 연결, 최근 파일, 저장 이름, 로그를 관리합니다."
                       Margin="0,5,0,0"
                       Foreground="{StaticResource MutedBrush}" />
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="Windows 연결">
                    <StackPanel>
                        <TextBlock x:Name="DefaultPdfAppText"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource InkBrush}" />
                        <TextBlock Text="Windows 10/11에서는 기본 앱 변경이 사용자 선택으로 보호될 수 있습니다."
                                   Margin="0,5,0,10"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource MutedBrush}" />
                        <WrapPanel>
                            <Button Content="기본 앱 설정 열기"
                                    Click="OnOpenDefaultAppsClick" />
                            <Button Content="상태 새로고침"
                                    Click="OnRefreshDefaultAppClick" />
                        </WrapPanel>
                        <CheckBox x:Name="ContextMenuCheckBox"
                                  Margin="0,12,0,0"
                                  Content="PDF 우클릭 통합 메뉴 사용" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="최근 파일">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="최근 파일 표시 개수"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource InkBrush}" />
                        <TextBox x:Name="RecentFileLimitTextBox"
                                 Grid.Column="1" />
                    </Grid>
                </GroupBox>

                <GroupBox Header="저장 이름">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="재정렬 저장"
                                   VerticalAlignment="Center" />
                        <TextBox x:Name="ReorderedSuffixTextBox"
                                 Grid.Column="1" />

                        <TextBlock Grid.Row="1"
                                   Text="통합 저장"
                                   Margin="0,8,0,0"
                                   VerticalAlignment="Center" />
                        <TextBox x:Name="MergedSuffixTextBox"
                                 Grid.Row="1"
                                 Grid.Column="1"
                                 Margin="0,8,0,0" />

                        <TextBlock Grid.Row="2"
                                   Text="A4 맞춤"
                                   Margin="0,8,0,0"
                                   VerticalAlignment="Center" />
                        <TextBox x:Name="A4FitSuffixTextBox"
                                 Grid.Row="2"
                                 Grid.Column="1"
                                 Margin="0,8,0,0" />

                        <TextBlock Grid.Row="3"
                                   Text="A4 최적화"
                                   Margin="0,8,0,0"
                                   VerticalAlignment="Center" />
                        <TextBox x:Name="A4OptimizedSuffixTextBox"
                                 Grid.Row="3"
                                 Grid.Column="1"
                                 Margin="0,8,0,0" />
                    </Grid>
                </GroupBox>

                <GroupBox Header="정리 및 로그">
                    <StackPanel>
                        <CheckBox x:Name="AutoCleanTempFilesCheckBox"
                                  Content="앱 시작 시 오래된 임시파일 자동 정리" />
                        <WrapPanel Margin="0,12,0,0">
                            <Button Content="임시파일 정리"
                                    Click="OnCleanTempFilesClick" />
                            <Button Content="로그 폴더 열기"
                                    Click="OnOpenLogsClick" />
                        </WrapPanel>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <DockPanel Grid.Row="2"
                   Margin="0,14,0,0"
                   LastChildFill="False">
            <Button Content="저장"
                    DockPanel.Dock="Right"
                    Width="92"
                    Click="OnSaveClick" />
            <Button Content="취소"
                    DockPanel.Dock="Right"
                    Width="92"
                    Click="OnCancelClick" />
        </DockPanel>
    </Grid>
</Window>
