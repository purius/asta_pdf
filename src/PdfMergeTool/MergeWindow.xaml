<Window x:Class="PdfMergeTool.MergeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="PDF 파일 합치기"
        Width="720"
        Height="620"
        MinWidth="620"
        MinHeight="520"
        Background="#F6F7F9"
        FontFamily="Segoe UI Variable, Segoe UI"
        AllowDrop="True"
        Drop="OnWindowDrop"
        DragOver="OnWindowDragOver">
    <Window.Resources>
        <SolidColorBrush x:Key="InkBrush" Color="#1F2328" />
        <SolidColorBrush x:Key="MutedBrush" Color="#667085" />
        <SolidColorBrush x:Key="LineBrush" Color="#D8DEE7" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1C7C54" />
        <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#166A47" />
        <SolidColorBrush x:Key="DangerBrush" Color="#BA3A3A" />
        <SolidColorBrush x:Key="FileIconBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="RemoveIconBrush" Color="#BA3A3A" />
        <SolidColorBrush x:Key="OrderIconBrush" Color="#0F766E" />
        <SolidColorBrush x:Key="SortIconBrush" Color="#7C3AED" />
        <SolidColorBrush x:Key="OutputIconBrush" Color="#B45309" />

        <Style x:Key="MergeToolbarIconStyle" TargetType="{x:Type iconPacks:PackIconMaterial}">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        </Style>
        <Style x:Key="FileMergeIconStyle" TargetType="{x:Type iconPacks:PackIconMaterial}"
               BasedOn="{StaticResource MergeToolbarIconStyle}">
            <Setter Property="Foreground" Value="{StaticResource FileIconBrush}" />
        </Style>
        <Style x:Key="RemoveMergeIconStyle" TargetType="{x:Type iconPacks:PackIconMaterial}"
               BasedOn="{StaticResource MergeToolbarIconStyle}">
            <Setter Property="Foreground" Value="{StaticResource RemoveIconBrush}" />
        </Style>
        <Style x:Key="OrderMergeIconStyle" TargetType="{x:Type iconPacks:PackIconMaterial}"
               BasedOn="{StaticResource MergeToolbarIconStyle}">
            <Setter Property="Foreground" Value="{StaticResource OrderIconBrush}" />
        </Style>
        <Style x:Key="SortMergeIconStyle" TargetType="{x:Type iconPacks:PackIconMaterial}"
               BasedOn="{StaticResource MergeToolbarIconStyle}">
            <Setter Property="Foreground" Value="{StaticResource SortIconBrush}" />
        </Style>
        <Style x:Key="OutputMergeIconStyle" TargetType="{x:Type iconPacks:PackIconMaterial}"
               BasedOn="{StaticResource MergeToolbarIconStyle}">
            <Setter Property="Foreground" Value="{StaticResource OutputIconBrush}" />
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F8FAFC" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#AEB8C8" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource PrimaryHoverBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource PrimaryHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconActionButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,8,8" />
        </Style>

        <Style x:Key="IconPrimaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,8,8" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemRoot"
                                Background="#FFFFFF"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="8">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemRoot" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                <Setter TargetName="ItemRoot" Property="Background" Value="#EEF8F2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="PDF 파일 합치기"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="{StaticResource InkBrush}" />
            <TextBlock Text="파일 순서를 정한 뒤 하나의 PDF로 저장합니다."
                       Margin="0,5,0,0"
                       Foreground="{StaticResource MutedBrush}" />
        </StackPanel>

        <WrapPanel Grid.Row="1" Margin="0,0,0,8">
            <Button Style="{StaticResource IconActionButton}"
                    ToolTip="PDF 추가"
                    Click="OnAddClick">
                <iconPacks:PackIconMaterial Kind="FileDocumentPlus"
                                            Style="{StaticResource FileMergeIconStyle}" />
            </Button>
            <Button Style="{StaticResource IconActionButton}"
                    ToolTip="선택 제거"
                    Click="OnRemoveClick">
                <iconPacks:PackIconMaterial Kind="TrashCanOutline"
                                            Style="{StaticResource RemoveMergeIconStyle}" />
            </Button>
            <Button Style="{StaticResource IconActionButton}"
                    ToolTip="위로"
                    Click="OnMoveUpClick">
                <iconPacks:PackIconMaterial Kind="ChevronUp"
                                            Style="{StaticResource OrderMergeIconStyle}" />
            </Button>
            <Button Style="{StaticResource IconActionButton}"
                    ToolTip="아래로"
                    Click="OnMoveDownClick">
                <iconPacks:PackIconMaterial Kind="ChevronDown"
                                            Style="{StaticResource OrderMergeIconStyle}" />
            </Button>
            <Button Style="{StaticResource IconActionButton}"
                    ToolTip="오름차순"
                    Click="OnSortAscendingClick">
                <iconPacks:PackIconMaterial Kind="SortAscending"
                                            Style="{StaticResource SortMergeIconStyle}" />
            </Button>
            <Button Style="{StaticResource IconActionButton}"
                    ToolTip="내림차순"
                    Click="OnSortDescendingClick">
                <iconPacks:PackIconMaterial Kind="SortDescending"
                                            Style="{StaticResource SortMergeIconStyle}" />
            </Button>
            <Button Style="{StaticResource IconActionButton}"
                    ToolTip="양면 스캔 섞기"
                    Click="OnInterleaveClick">
                <iconPacks:PackIconMaterial Kind="SwapVertical"
                                            Style="{StaticResource SortMergeIconStyle}" />
            </Button>
            <Button Style="{StaticResource IconActionButton}"
                    ToolTip="저장 위치"
                    Click="OnChooseOutputClick">
                <iconPacks:PackIconMaterial Kind="FolderOpen"
                                            Style="{StaticResource OutputMergeIconStyle}" />
            </Button>
        </WrapPanel>

        <ListBox x:Name="FilesList"
                 Grid.Row="2"
                 ItemsSource="{Binding Files}"
                 SelectionMode="Extended"
                 AllowDrop="True"
                 Background="#F8FAFC"
                 BorderBrush="{StaticResource LineBrush}"
                 BorderThickness="1"
                 Padding="10"
                 PreviewMouseLeftButtonDown="OnFilesListMouseLeftButtonDown"
                 MouseMove="OnFilesListMouseMove"
                 Drop="OnFilesListDrop"
                 DragOver="OnWindowDragOver">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid MinHeight="32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="150" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding FileName}"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding PageRange, UpdateSourceTrigger=PropertyChanged}"
                                 Height="26"
                                 Margin="12,0,0,0"
                                 Padding="7,2"
                                 VerticalContentAlignment="Center"
                                 ToolTip="비워두면 전체 페이지입니다. 예: 1-3,5,8-z" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Grid Grid.Row="3" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="130" />
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="저장 위치"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource MutedBrush}" />
                <TextBlock x:Name="OutputPathText"
                           Margin="0,4,0,0"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
            <Button x:Name="MergeButton"
                    Grid.Column="1"
                    Content="통합"
                    Height="42"
                    Style="{StaticResource PrimaryButton}"
                    Click="OnMergeClick" />
        </Grid>
    </Grid>
</Window>
